<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.NotificationMapper">

    <!--
        NOTIFICATION 테이블 컬럼:
        id, sendType, sendName, title, text, sendId, recvId,
        is_read, create_date, notification_img

        수정: 이전 member_email/type/message/url 구조 → 새 구조로 전면 변경
    -->
    <resultMap id="notiResultMap" type="dto.common.NotificationDTO">
        <id     property="id"              column="id"/>
        <result property="sendType"        column="sendType"/>
        <result property="sendName"        column="sendName"/>
        <result property="title"           column="title"/>
        <result property="text"            column="text"/>
        <result property="sendId"          column="sendId"/>
        <result property="recvId"          column="recvId"/>
        <result property="isRead"          column="is_read"/>
        <result property="createDate"      column="create_date"/>
        <result property="notificationImg" column="notification_img"/>
    </resultMap>

    <!-- recvId(=수신자)로 알림 목록 조회 -->
    <select id="findByRecvId" parameterType="string" resultMap="notiResultMap">
        SELECT id, sendType, sendName, title, text,
               sendId, recvId, is_read, create_date, notification_img
        FROM NOTIFICATION
        WHERE recvId = #{recvId}
        ORDER BY id DESC
    </select>

    <!-- 안읽은 알림 수 -->
    <select id="countUnread" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM NOTIFICATION
        WHERE recvId = #{recvId} AND is_read = 0
    </select>

    <!-- 알림 저장 -->
    <insert id="insert" parameterType="dto.common.NotificationDTO">
        INSERT INTO NOTIFICATION (
            sendType, sendName, title, text,
            sendId, recvId, is_read, notification_img
        ) VALUES (
            #{sendType}, #{sendName}, #{title}, #{text},
            #{sendId}, #{recvId}, 0, #{notificationImg}
        )
    </insert>

    <!-- 전체 읽음 처리 -->
    <update id="updateReadAll" parameterType="string">
        UPDATE NOTIFICATION SET is_read = 1 WHERE recvId = #{recvId}
    </update>

    <!-- 개별 읽음 처리 -->
    <update id="updateReadOne" parameterType="int">
        UPDATE NOTIFICATION SET is_read = 1 WHERE id = #{id}
    </update>

</mapper>
