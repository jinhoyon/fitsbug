<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.MessageMapper">

    <resultMap id="messageResultMap" type="dto.member.MessageDTO">
        <id     property="id"       column="id"/>
        <result property="sender"   column="sender"/>
        <result property="receiver" column="receiver"/>
        <result property="content"  column="content"/>
        <result property="sendTime" column="send_time"/>
        <result property="isRead"   column="is_read"/>
    </resultMap>

    <resultMap id="roomResultMap" type="dto.member.MessageRoomDTO">
        <result property="email"       column="chat_user"/>
        <result property="nickname"    column="nickname"/>
        <result property="lastMessage" column="last_message"/>
        <result property="unreadCount" column="unread_count"/>
    </resultMap>

    <!-- ──────────────────────────────────────────────────────
         MessageDAOImpl.insert(MessageDTO dto)
         → param: MessageDTO
         ────────────────────────────────────────────────────── -->
    <insert id="insert" parameterType="MessageDTO">
        INSERT INTO message (sender, receiver, content, send_time, is_read)
        VALUES (#{sender}, #{receiver}, #{content}, NOW(), 0)
    </insert>

    <!-- ──────────────────────────────────────────────────────
         MessageDAOImpl.getChatList(String sender, String receiver)
         → Map 키: sender / receiver
         ────────────────────────────────────────────────────── -->
    <select id="getChatList" parameterType="map" resultMap="messageResultMap">
        SELECT id, sender, receiver, content, send_time, is_read
        FROM message
        WHERE (sender = #{sender} AND receiver = #{receiver})
           OR (sender = #{receiver} AND receiver = #{sender})
        ORDER BY send_time ASC
    </select>

    <!-- ──────────────────────────────────────────────────────
         MessageDAOImpl.updateRead(int messageId)
         → param: int (단일 값)
         ────────────────────────────────────────────────────── -->
    <update id="updateRead" parameterType="int">
        UPDATE message SET is_read = 1 WHERE id = #{id}
    </update>

    <!-- ──────────────────────────────────────────────────────
         MessageDAOImpl.getUnreadCount(String receiver)
         → param: string
         ────────────────────────────────────────────────────── -->
    <select id="getUnreadCount" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM message
        WHERE receiver = #{receiver} AND is_read = 0
    </select>

    <!-- ──────────────────────────────────────────────────────
         MessageDAOImpl.markAsRead(String sender, String receiver)
         → Map 키: sender / receiver
         ────────────────────────────────────────────────────── -->
    <update id="markAsRead" parameterType="map">
        UPDATE message
        SET is_read = 1
        WHERE sender = #{sender} AND receiver = #{receiver}
    </update>

    <!-- ──────────────────────────────────────────────────────
         MessageDAOImpl.getMessageRoomList(String email)
         → param: string  (#{email} 단일 참조, 여러 번 사용)
         ────────────────────────────────────────────────────── -->
    <select id="getMessageRoomList" parameterType="string" resultMap="roomResultMap">
        SELECT
            CASE WHEN sender = #{email} THEN receiver ELSE sender END AS chat_user,
            mb.nickname AS nickname,
            MAX(content)  AS last_message,
            SUM(CASE WHEN receiver = #{email} AND is_read = 0 THEN 1 ELSE 0 END) AS unread_count
        FROM message m
        LEFT JOIN member mb
            ON mb.email = CASE WHEN sender = #{email} THEN receiver ELSE sender END
        WHERE sender = #{email} OR receiver = #{email}
        GROUP BY chat_user, mb.nickname
        ORDER BY MAX(send_time) DESC
    </select>

</mapper>