<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.TrainerCertificationMapper">

    <resultMap id="certResultMap" type="dto.common.CertificationDTO">
        <id     property="id"          column="id"/>
        <result property="trainerId"   column="trainer_id"/>
        <result property="certName"    column="cert_name"/>
        <result property="issuingOrg"  column="issuing_org"/>
        <result property="issueDate"   column="issue_date"/>
        <result property="expiryDate"  column="expiry_date"/>
        <result property="certFile"    column="cert_file"/>
        <result property="createdAt"   column="created_at"/>
    </resultMap>

    <!-- 자격증 저장 -->
    <insert id="insert" parameterType="dto.common.CertificationDTO">
        INSERT INTO TRAINER_CERTIFICATION
            (trainer_id, cert_name, issuing_org, issue_date, expiry_date, cert_file)
        VALUES
            (#{trainerId}, #{certName}, #{issuingOrg}, #{issueDate}, #{expiryDate}, #{certFile})
    </insert>

    <!-- trainer_id로 자격증 목록 조회 -->
    <select id="findByTrainerId" parameterType="int" resultMap="certResultMap">
        SELECT id, trainer_id, cert_name, issuing_org,
               issue_date, expiry_date, cert_file, created_at
        FROM TRAINER_CERTIFICATION
        WHERE trainer_id = #{trainerId}
        ORDER BY issue_date DESC
    </select>

    <!-- 자격증 삭제 -->
    <delete id="delete" parameterType="int">
        DELETE FROM TRAINER_CERTIFICATION WHERE id = #{id}
    </delete>

</mapper>
