<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.member.trainer_traits">

    <resultMap id="traitResultMap" type="dto.member.TrainerTraitsDTO">
        <id     property="id"        column="id"/>
        <result property="trainerId" column="trainer_id"/>
        <result property="type"      column="TYPE"/>
    </resultMap>

    <!-- 특성 저장 -->
    <insert id="insert" parameterType="dto.member.TrainerTraitsDTO">
        INSERT INTO TRAINER_TRAITS (trainer_id, TYPE)
        VALUES (#{trainerId}, #{type})
    </insert>

    <!-- trainer_id로 특성 목록 조회 -->
    <select id="findByTrainerId" parameterType="int" resultMap="traitResultMap">
        SELECT id, trainer_id, TYPE
        FROM TRAINER_TRAITS
        WHERE trainer_id = #{trainerId}
        ORDER BY id ASC
    </select>

    <!-- trainer_id로 전체 삭제 (수정 시 전체 재등록용) -->
    <delete id="deleteByTrainerId" parameterType="int">
        DELETE FROM TRAINER_TRAITS WHERE trainer_id = #{trainerId}
    </delete>

</mapper>
