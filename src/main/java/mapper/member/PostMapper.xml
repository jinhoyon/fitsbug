<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.PostMapper">

    <!--
        PostDTO 필드 매핑
        userId = Integer (USER.id FK)
        리액션 집계 필드는 PostDTO에 없으므로 resultMap 미포함
        → 리액션 카운트는 ReactionCountController AJAX로 별도 조회
    -->
    <resultMap id="postResultMap" type="PostDTO">
        <id     property="id"          column="id"/>
        <result property="userId"      column="user_id"/>
        <result property="postType"    column="post_type"/>
        <result property="title"       column="title"/>
        <result property="body"        column="body"/>
        <result property="image"       column="image"/>
        <result property="hashtags"    column="hashtags"/>
        <result property="recommended" column="recommended"/>
        <result property="createdAt"   column="created_at"/>
        <result property="status"      column="status"/>
    </resultMap>

    <insert id="insert" parameterType="PostDTO">
        INSERT INTO post (user_id, post_type, title, body, image, hashtags, status)
        VALUES (#{userId}, #{postType}, #{title}, #{body}, #{image}, #{hashtags}, 'normal')
    </insert>

    <!-- u.nickname을 user_id alias로 매핑 → PostDTO.userId에 닉네임이 담김 -->
    <select id="getList" resultType="PostDTO">
        SELECT
            p.id,
            p.user_id,
            u.nickname,
            u.profile_image,
            p.post_type,
            p.title,
            p.body,
            p.image,
            p.hashtags,
            p.recommended,
            p.created_at,
            p.status
        FROM post p
        LEFT JOIN user u ON p.user_id = u.id
        WHERE p.status = 'normal' OR p.status IS NULL
        ORDER BY p.id DESC
    </select>

    <!--
        getWriterEmail
        - 기존: post.user_id(INTEGER) 를 email로 반환했는데 오류
        - 수정: USER 테이블 JOIN 해서 email 반환
    -->
    <select id="getWriterEmail" parameterType="int" resultType="string">
        SELECT u.email
        FROM post p
        INNER JOIN user u ON p.user_id = u.id
        WHERE p.id = #{postId}
    </select>

</mapper>
