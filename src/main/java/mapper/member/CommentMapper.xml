<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.CommentMapper">

    <resultMap id="commentResultMap" type="dto.member.CommentDTO">
        <id     property="id"        column="id"/>
        <result property="postNum"    column="post_num"/>
        <result property="userId"  column="user_id"/>
        <result property="body"   column="body"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>
    
    <!--
        INSERT
        comment.user_id = INTEGER (USER.id FK)
        CommentDTO.userId = String(email)
        → 서브쿼리로 email → user_id 변환
    -->
    <insert id="insert" parameterType="CommentDTO">
        INSERT INTO comment (post_num, user_id, body)
        VALUES (
            #{postNum},
            (SELECT id FROM user WHERE email = #{userId}),
            #{body}
        )
    </insert>

    <!--
        SELECT
        user_id(INTEGER) → email(String) JOIN 후 CommentDTO.userId에 매핑
    -->
    <select id="findByPostNum" parameterType="int" resultMap="commentResultMap">
        SELECT c.id, c.post_num, u.nickname AS user_id, c.body, c.created_at
        FROM comment c
        INNER JOIN user u ON c.user_id = u.id
        WHERE c.post_num = #{postNum}
        ORDER BY c.id ASC
    </select>

</mapper>
