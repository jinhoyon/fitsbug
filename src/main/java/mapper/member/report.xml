<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="mapper.member.report">

    <!--
        REPORT 테이블 컬럼:
        id, reporter_id, target_id, post_id,
        category, title, content, file, result,
        status(WAIT/REJECT/HIDE), reg_date, process_date

        수정: 이전 post_id/reason/detail/user_id 단순 구조 → 전체 컬럼으로 재작성
    -->
    <resultMap id="reportResultMap" type="dto.member.ReportDTO">
        <id     property="id"          column="id"/>
        <result property="reporterId"  column="reporter_id"/>
        <result property="targetId"    column="target_id"/>
        <result property="postId"      column="post_id"/>
        <result property="category"    column="category"/>
        <result property="title"       column="title"/>
        <result property="content"     column="content"/>
        <result property="file"        column="file"/>
        <result property="result"      column="result"/>
        <result property="status"      column="status"/>
        <result property="regDate"     column="reg_date"/>
        <result property="processDate" column="process_date"/>
    </resultMap>

    <!-- 신고 저장 -->
    <insert id="insert" parameterType="dto.member.ReportDTO">
        INSERT INTO REPORT (reporter_id, target_id, post_id, category, content)
        VALUES (#{reporterId}, #{targetId}, #{postId}, #{category}, #{content})
    </insert>

    <!-- 신고된 게시글 숨김 처리 -->
    <update id="hidePost" parameterType="int">
        UPDATE POST SET status = 'hidden' WHERE id = #{postId}
    </update>

    <!-- 신고 목록 전체 조회 (관리자용) -->
    <select id="findAll" resultMap="reportResultMap">
        SELECT id, reporter_id, target_id, post_id,
               category, title, content, file, result,
               status, reg_date, process_date
        FROM REPORT
        ORDER BY id DESC
    </select>

    <!-- 상태 업데이트 (관리자 처리) -->
    <update id="updateStatus" parameterType="map">
        UPDATE REPORT
        SET status       = #{status},
            result       = #{result},
            process_date = NOW()
        WHERE id = #{id}
    </update>

</mapper>
